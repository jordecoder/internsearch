# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
# Your Telegram user/group chat ID (send a message to @userinfobot to find it)
TELEGRAM_CHAT_ID=123456789

# ── FastAPI / Auth ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string
# Shared with friends so they can create accounts
INVITE_CODE=my-secret-invite-code

# ── Database ──────────────────────────────────────────────────────────────────
# Recommended: Neon free-tier Postgres (https://neon.tech)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
# SQLite fallback path (used only when DATABASE_URL is not set)
USERS_DB_PATH=/tmp/internsearch_users.db

# ── Gemini (RAG) ──────────────────────────────────────────────────────────────
# Create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── GitHub (apply tracker) ────────────────────────────────────────────────────
# Create a PAT at https://github.com/settings/tokens with repo scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=jordecoder/internsearch

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Upstash Kafka (free tier, no credit card): https://console.upstash.com/kafka
#   Bootstrap: your-cluster.upstash.io:9092
#   SASL mechanism: SCRAM-SHA-256
# Confluent Cloud (free trial): https://confluent.io
#   Bootstrap: pkc-xxxx.us-east-1.aws.confluent.cloud:9092
#   SASL mechanism: PLAIN
KAFKA_BOOTSTRAP_SERVERS=your-cluster.upstash.io:9092
KAFKA_API_KEY=your-upstash-username
KAFKA_API_SECRET=your-upstash-password
KAFKA_SASL_MECHANISM=SCRAM-SHA-256

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://jordecoder.github.io

# ── Observability (optional) ──────────────────────────────────────────────────
# Create a free project at https://sentry.io — paste the DSN here
SENTRY_DSN=
